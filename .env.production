# Temporary: public, read-only Hygraph endpoint so production builds (Vercel)
# have blog / tag / project content without per-environment configuration.
# This URL is NOT a secret — it is the published-content read API the live
# site already exposes. Secrets (GRAPHCMS_TOKEN, SPOTIFY_*, etc.) are
# intentionally NOT committed here; set those in the Vercel dashboard and
# rotate the ones leaked in git history. Remove this file once env vars are
# configured in Vercel.
NEXT_PUBLIC_GRAPHCMS_ENDPOINT=https://ap-southeast-2.cdn.hygraph.com/content/cl153jqjog8tm01zagkyr7x6c/master
